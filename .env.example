# SEX SLAVE DUNGEON — environment variables (LOCAL DEV ONLY)
#
# This file is a TEMPLATE committed to the repo. Copy it to `.env` (gitignored) and fill in real values.
# On GitHub Pages / any static deploy, these values are NOT used at runtime — the visitor supplies
# their own values via the Settings panel in the landing page. This file exists only for local
# development convenience.

# Pollinations API token — for image generation and optional fallback text
# Get yours at https://pollinations.ai (BYOP — Bring Your Own Pollen)
POLLINATIONS_API_KEY=sk_your_pollinations_key_here

# Ollama endpoint — default localhost:11434. Change only if running Ollama on a non-default port.
OLLAMA_ENDPOINT=http://localhost:11434

# Preferred Ollama model for Unity / girl personas.
# Dolphin family is the right choice for uncensored + scripted-template work:
# strong system-prompt adherence, classic community-proven, low refusal rate.
# dolphin-mistral:7b is the safe default (~4.1GB, runs everywhere).
# Alternatives: dolphin3:8b (newer Llama3.1 base), dolphin-llama3:8b, dolphin-mixtral:8x7b (~26GB).
OLLAMA_MODEL=dolphin-mistral:7b

# Kokoro model path (leave default — loaded in-browser from CDN)
KOKORO_MODEL=onnx-community/Kokoro-82M-v1.0-ONNX

# Dev flags
DEV_MODE=true
